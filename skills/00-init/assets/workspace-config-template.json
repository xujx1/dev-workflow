{
  "version": "1.0",
  "layer": "workspace",
  "_description": "项目集级配置，同一 monorepo 内共享的配置",
  "_maintainer": "技术负责人",
  "shared_knowledge_base": "shared-knowledge-base/",
  "autofix": {
    "max_attempts": 3,
    "timeout_minutes": 5,
    "min_pass_rate": 100,
    "stop_on_regression": true,
    "stop_on_no_progress_rounds": 2
  },
  "common_dependencies": {
    "spring_boot_version": "3.2.0",
    "java_version": "17"
  },
  "monorepo": {
    "root": "${MONOREPO_ROOT}",
    "_source": "自动检测 monorepo 根目录"
  }
}
