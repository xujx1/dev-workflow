{
  "project": {
    "name": "example-project",
    "tech_stack": "java-spring-boot",
    "test_framework": "junit5+mockito",
    "package_manager": "maven",
    "directory_convention": "layered"
  },
  "knowledge_base": {
    "root": "knowledge-base/",
    "context_file": "knowledge-base/CONTEXT.md"
  },
  "code_gen": {
    "template_set": "java-spring-boot-v2",
    "mock_strategy": "mock-first"
  },
  "env": {
    "java_version": "1.8.0_482",
    "maven_version": "3.9.12",
    "maven_path": "/Users/admin/maven/maven/3.9.12/bin/mvn",
    "maven_settings": "",
    "test_deps_junit5": false,
    "test_deps_junit_version": 4,
    "test_deps_mockito": true,
    "env_confirmed": true
  },
  "openspec": {
    "enabled": true,
    "threshold_person_days": 5,
    "generate_stage": "before_code_gen",
    "archive_in_stage4": true
  },
  "test_runtime": {
    "enabled": true,
    "mode": "mock-first"
  },
  "plugin_availability": {
    "l0_ecc": "available",
    "l0_ecc_rules": "unavailable",
    "l1_rtk": "available",
    "l2_gitnexus": "not_indexed",
    "l3_autoresearch": "available",
    "l4_pua": "unavailable"
  },
  "autofix": {
    "max_attempts": 3,
    "timeout_minutes": 5,
    "min_pass_rate": 100,
    "stop_on_regression": true,
    "stop_on_no_progress_rounds": 2
  }
}